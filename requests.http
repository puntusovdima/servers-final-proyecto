@baseUrl = http://localhost:3000/api
@token = YOUR_JWT_TOKEN_HERE

### Health Check
GET {{baseUrl}}/health

### 1. User Registration
POST {{baseUrl}}/user/register
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "password123"
}

### 2. Login
POST {{baseUrl}}/user/login
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "password123"
}

### 3. Get Current User
GET {{baseUrl}}/user
Authorization: Bearer {{token}}

### 4. Create Client
POST {{baseUrl}}/client
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Acme Corp",
  "cif": "A12345678",
  "email": "contact@acme.com",
  "phone": "912345678",
  "address": {
    "street": "Main St",
    "number": "100",
    "postal": "28001",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### 5. List Clients
GET {{baseUrl}}/client?page=1&limit=10
Authorization: Bearer {{token}}

### 6. Create Project
POST {{baseUrl}}/project
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "client": "CLIENT_ID_HERE",
  "name": "Office Renovation",
  "projectCode": "PRJ-001",
  "email": "office@acme.com",
  "address": {
    "street": "Broadway",
    "number": "1",
    "postal": "28001",
    "city": "Madrid",
    "province": "Madrid"
  }
}

### 7. List Projects
GET {{baseUrl}}/project?active=true
Authorization: Bearer {{token}}

### 8. Create Delivery Note
POST {{baseUrl}}/deliverynote
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "project": "PROJECT_ID_HERE",
  "client": "CLIENT_ID_HERE",
  "format": "hours",
  "hours": 8,
  "description": "General maintenance",
  "workDate": "2024-03-20"
}

### 9. List Delivery Notes
GET {{baseUrl}}/deliverynote?signed=false
Authorization: Bearer {{token}}

### 10. Sign Delivery Note (Multipart)
# Use a tool like Postman or VS Code Rest Client extension for multipart/form-data
# PATCH {{baseUrl}}/deliverynote/ID/sign
# Authorization: Bearer {{token}}
# Content-Type: multipart/form-data; boundary=boundary

### 11. Download PDF
GET {{baseUrl}}/deliverynote/pdf/ID_HERE
Authorization: Bearer {{token}}
